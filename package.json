{
  "name": "sgd-rrhh-back",
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/core/server/server.ts",
    "start": "node dist/core/server/server.js",
    "build": "tsc && tsc-alias",
    "db:seed": "tsx db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:up": "ts-node src/scripts/db-up.ts",
    "db:ping": "ts-node src/scripts/db-ping.ts",
    "db:studio": "drizzle-kit studio --port 4321",
    "db:reset": "tsx src/scripts/db-reset.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "swagger": "open-cli http://localhost:3000/api-docs/#/",
    "prepare": "husky",
    "seeders:generate": "tsx src/scripts/seed/index.ts generate",
    "seeders": "tsx src/scripts/seed/index.ts run",
    "seeders:rollback": "tsx src/scripts/seed/index.ts undo",
    "db:seed:run:specific": "tsx src/db/seed/cli/index.ts run --specific",
    "db:seed:undo:specific": "tsx src/db/seed/cli/index.ts undo --specific"
  },
  "keywords": [],
  "author": "Ignacio Nicoletti",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.1",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "express": "^5.1.0",
    "husky": "^9.1.7",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.6",
    "nodemon": "^3.1.10",
    "open-cli": "^8.0.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
