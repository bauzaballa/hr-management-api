{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
     "baseUrl": "./src",
    "paths": {
      "@schemas/*": ["app/entities/*"],
      "@core/*": ["core/*"],
      "@shared/*": ["shared/*"],
      "@components/*": ["app/components/*"]
    }
  },
  "include": ["src/**/*", "app.ts", "server.ts"],
  "exclude": ["node_modules"]
}