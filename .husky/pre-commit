#!/usr/bin/env sh
set -e

echo "🧹 Ejecutando Biome (format + lint)..."

# Obtener solo los archivos staged (agregados, copiados o modificados)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.ts$|\.tsx$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "📄 Archivos a formatear:"
  echo "$STAGED_FILES"

  # Ejecutar Biome solo sobre los archivos staged
  npx biome format --write $STAGED_FILES || {
    echo "❌ Error al formatear con Biome."
    exit 1
  }

  # Reagregar solo los archivos modificados
  echo "$STAGED_FILES" | xargs git add
else
  echo "ℹ️ No hay archivos TypeScript staged para formatear."
fi

echo "✅ Commit permitido!"
